{
  "name": "shop-admin",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "shop-admin open source management system",
  "author": {
    "name": "Shop",
    "email": "liujitcn@gmail.com",
    "url": "https://github.com/liujitcn"
  },
  "license": "MIT",
  "homepage": "https://github.com/liujitcn/shop",
  "repository": {
    "type": "git",
    "url": "git@github.com:liujitcn/shop.git"
  },
  "bugs": {
    "url": "https://github.com/liujitcn/shop/issues"
  },
  "scripts": {
    "dev": "vite",
    "serve": "vite",
    "build": "pnpm build:pro",
    "build:dev": "vue-tsc && vite build --mode development",
    "build:test": "vue-tsc && vite build --mode test",
    "build:pro": "vue-tsc && vite build --mode production",
    "type:check": "vue-tsc --noEmit --skipLibCheck",
    "preview": "pnpm build:dev && vite preview",
    "lint:oxlint": "oxlint --fix --vue-plugin --ignore-path .oxlintignore ./src ./build vite.config.ts lint-staged.config.cjs",
    "lint:prettier": "prettier --write \"src/**/*.{js,ts,json,tsx,css,less,scss,vue,html,md}\"",
    "lint:stylelint": "stylelint --cache --fix \"**/*.{vue,less,postcss,css,scss}\" --cache --cache-location node_modules/.cache/stylelint/",
    "lint:lint-staged": "lint-staged",
    "release": "standard-version",
    "commit": "git add -A && czg && git push"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@logicflow/core": "^2.2.1",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@shikijs/core": "^3.23.0",
    "@vueuse/core": "^14.3.0",
    "@wangeditor/editor": "^5.1.23",
    "@wangeditor/editor-for-vue": "^5.1.12",
    "axios": "^1.7.2",
    "dagre": "^0.8.5",
    "dayjs": "^1.11.21",
    "driver.js": "^1.3.1",
    "echarts": "^5.5.1",
    "echarts-liquidfill": "^3.1.0",
    "element-plus": "^2.7.6",
    "hook-fetch": "^2.3.2",
    "md5": "^2.3.0",
    "mitt": "^3.0.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "qs": "^6.12.1",
    "screenfull": "^6.0.2",
    "sortablejs": "^1.15.2",
    "vue": "^3.5.35",
    "vue-element-plus-x": "^2.0.3",
    "vue-router": "^5.0.7",
    "vuedraggable": "^4.1.0",
    "x-markdown-vue": "^0.0.200"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@types/dagre": "^0.7.54",
    "@types/md5": "^2.3.5",
    "@types/node": "^25.9.1",
    "@types/nprogress": "^0.2.3",
    "@types/qs": "^6.9.15",
    "@types/sortablejs": "^1.15.8",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "autoprefixer": "^10.4.19",
    "code-inspector-plugin": "^1.5.1",
    "cz-git": "1.13.1",
    "czg": "^1.13.1",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.5",
    "oxlint": "^1.67.0",
    "postcss": "^8.4.38",
    "postcss-html": "^1.8.1",
    "prettier": "^3.3.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.100.0",
    "standard-version": "^9.5.0",
    "stylelint": "^17.12.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.5.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "8.1.1",
    "terser": "^5.48.0",
    "ts-proto": "^2.11.8",
    "typescript": "6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "unplugin-vue-setup-extend-plus": "^1.0.1",
    "vite": "^8.0.14",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-tsc": "^3.3.2"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "browserslist": {
    "production": [
      "> 1%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "pnpm": {
    "overrides": {
      "@logicflow/core>uuid": "11.1.1",
      "svg-baker>braces": "3.0.3",
      "svg-baker>micromatch": "4.0.8",
      "svg-baker>postcss": "8.5.15"
    },
    "onlyBuiltDependencies": [
      "@logicflow/core",
      "@parcel/watcher",
      "es5-ext",
      "esbuild",
      "vue-demi",
      "workbox-build"
    ]
  }
}
